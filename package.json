{
  "name": "works-os",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "kill-port 3080 5173 && concurrently \"npm run dev -w server\" \"npm run dev -w web\"",
    "build": "npm run build -w shared && npm run build -w server && npm run build -w web",
    "migrate": "npm run migrate -w server",
    "migrate:deploy": "npm run migrate:deploy -w server",
    "seed": "npm run seed -w server",
    "lint": "npm run lint -w web",
    "test": "npm run test -w server"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "eslint": "^9.15.0",
    "kill-port": "^2.0.1",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3"
  }
}
